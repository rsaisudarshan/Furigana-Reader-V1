{
  "manifest_version": 3,
  "name": "Furigana Reader",
  "version": "1.0",
  "description": "Automatically generates furigana above Japanese kanji.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/active.png"
    }
  },
  "icons": {
    "128": "icons/active.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["dict/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/kuroshiro.min.js",
        "lib/kuroshiro-analyzer-kuromoji.min.js",
        "content.js"
      ]
    }
  ]
}